# Copy to `.env.local` for local overrides (not committed).
# Mock API (default): keep mocks on until Rails JSON endpoints match `src/services/api.ts`.
VITE_USE_MOCKS=true

# Rails API base URL when `VITE_USE_MOCKS=false` (no trailing slash), e.g. http://localhost:3000
# VITE_API_BASE_URL=http://localhost:3000
