<h2>Mock Stripe Checkout</h2>

<p>Use this page to simulate a payment flow without charging real cards.</p>

<% if notice.present? %>
  <p style="color: green;"><%= notice %></p>
<% end %>
<% if alert.present? %>
  <p style="color: red;"><%= alert %></p>
<% end %>

<%= form_with url: "/payments/mock_checkout", method: :post, local: true do |f| %>
  <div>
    <%= f.label :item_name, "Item name" %><br>
    <%= f.text_field :item_name, value: "Desk Lamp" %>
  </div>
  <div style="margin-top: 10px;">
    <%= f.label :amount, "Amount (HKD)" %><br>
    <%= f.number_field :amount, value: 120, min: 1 %>
  </div>
  <div style="margin-top: 10px;">
    <%= f.submit "Pay with Stripe (mock)" %>
  </div>
<% end %>
